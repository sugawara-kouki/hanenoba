<div class="<%= card_classes %>">
  <%# 選択用レイヤー (Absolute) %>
  <div class="absolute top-6 left-6 z-20">
    <label class="relative block h-8 w-8 cursor-pointer group/cb">
      <input type="checkbox" name="event_ids[]" value="<%= event.id %>" 
             class="peer absolute inset-0 opacity-0 z-10 cursor-pointer disabled:cursor-not-allowed"
             data-bulk-booking-target="checkbox"
             data-action="change->bulk-booking#toggle"
             aria-label="<%= event.title %>"
             <%= "disabled" if disabled? %>>
      <div class="absolute inset-0 bg-white/90 backdrop-blur-sm rounded-xl peer-checked:bg-indigo-600 ring-2 ring-indigo-600/20 peer-checked:ring-indigo-600 transition-all duration-300 peer-disabled:opacity-20 peer-disabled:grayscale flex items-center justify-center shadow-lg peer-checked:shadow-indigo-500/50">
      </div>
      <svg class="absolute inset-0 m-auto h-4 w-4 text-white scale-50 opacity-0 peer-checked:scale-100 peer-checked:opacity-100 transition-all duration-300 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)] pointer-events-none z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7" />
      </svg>
    </label>
  </div>

  <%# ステータスバッジ (Absolute) %>
  <div class="absolute top-6 right-6 z-20">
    <% if booked? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-green-500 text-white shadow-lg shadow-green-500/20"><%= t('events.card.applied') %></span>
    <% elsif full? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-gray-500 text-white"><%= t('events.card.full') %></span>
    <% end %>
  </div>

  <%# ビジュアルエリア %>
  <div class="relative h-48 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/80 to-purple-700/80 mix-blend-multiply z-10 transition-all duration-500 group-hover:scale-110"></div>
    <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80&v=<%= event.id %>" 
         class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-110" 
         alt="<%= event.title %>">
    
    <div class="absolute inset-0 z-10 flex items-center justify-center">
       <span class="text-white text-3xl font-black opacity-40 uppercase tracking-[0.2em] transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 text-center px-4">
         <%= event.event_type.name %>
       </span>
    </div>
  </div>

  <%# コンテンツ %>
  <div class="p-8 flex flex-col flex-grow">
    <div class="flex items-center space-x-2 mb-4">
      <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-tighter bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10">
        <%= event.event_type.name %>
      </span>
      <span class="h-1 w-1 rounded-full bg-gray-300"></span>
      <span class="text-[10px] text-gray-400 font-black uppercase tracking-widest">
        <%= t('events.card.capacity_text', count: event.capacity) %>
      </span>
    </div>

    <h3 class="text-xl font-black text-gray-900 group-hover:text-indigo-600 transition-colors leading-tight mb-4">
      <%= event.title %>
    </h3>

    <div class="mt-auto space-y-3">
      <div class="flex items-center text-sm font-bold text-gray-500">
        <div class="bg-indigo-50 p-1.5 rounded-lg mr-3 text-indigo-500">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <%= l(event.held_at, format: :dot_date) %> 
        <span class="mx-2 text-gray-200">/</span>
        <%= t('events.card.time_range', start_time: l(event.held_at, format: :hm)) %>
      </div>
      
      <div class="flex items-center text-sm font-bold text-gray-500">
        <div class="bg-purple-50 p-1.5 rounded-lg mr-3 text-purple-500">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
        </div>
        <%= event.location.presence || t('events.card.tbd') %>
      </div>
    </div>

    <div class="mt-8">
      <%= link_to event_path(event), class: "w-full py-4 px-6 rounded-2xl bg-gray-50 text-gray-900 font-black text-sm text-center block transition-all hover:bg-gray-900 hover:text-white active:scale-95" do %>
        <%= t('events.card.details') %>
      <% end %>
    </div>
  </div>
</div>
