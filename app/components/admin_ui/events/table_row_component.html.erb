<tr class="hover:bg-gray-50/30 transition-colors">
  <%# イベント名 %>
  <td class="py-5 pl-8 pr-3">
    <div class="flex flex-col space-y-1">
      <span class="inline-flex items-center w-fit px-2 py-0.5 rounded-md text-[10px] font-bold bg-indigo-50 text-indigo-600 ring-1 ring-indigo-500/10 uppercase tracking-tighter">
        <%= event.event_type.name %>
      </span>
      <span class="text-base font-bold text-gray-900 leading-snug"><%= event.title %></span>
      <div class="flex items-center text-xs text-gray-400 font-medium">
        <%= icon(:location, class: "h-3 w-3 mr-1 opacity-50") %>
        <%= event.location %>
      </div>
    </div>
  </td>
  <%# 開催日時 %>
  <td class="whitespace-nowrap px-3 py-5">
    <div class="tabular-nums">
      <div class="text-gray-900 font-semibold text-sm"><%= l(event.held_at, format: :dot_date) %></div>
      <div class="text-xs text-gray-400 font-medium mt-0.5"><%= l(event.held_at, format: :hm) %>〜</div>
    </div>
  </td>
  <%# 申し込み状況 %>
  <td class="whitespace-nowrap px-3 py-5">
    <div class="flex flex-col space-y-1.5">
      <div class="flex justify-between items-baseline tabular-nums">
        <span class="text-sm font-semibold text-gray-700"><%= event.current_bookings_count %> / <%= event.capacity %></span>
        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-tighter"><%= event.occupancy_rate %>%</span>
      </div>
      <div class="w-full bg-gray-100 rounded-full h-1 overflow-hidden">
        <div class="bg-indigo-600 h-1 rounded-full shadow-[0_0_4px_rgba(79,70,229,0.3)]" style="width: <%= [event.occupancy_rate, 100].min %>%"></div>
      </div>
    </div>
  </td>
  <%# ステータス %>
  <td class="whitespace-nowrap px-3 py-5">
    <%= render AdminUi::BadgeComponent.new(status: event.status) %>
  </td>
  <%# 操作ボタン %>
  <td class="whitespace-nowrap py-5 pl-3 pr-8 text-right font-medium">
    <div class="flex items-center justify-end -space-x-px">
      <%= link_to [:admin, event], class: "p-2 rounded-l-xl border border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: t('common.actions.show') do %>
        <%= icon(:eye, class: "w-4 h-4") %>
      <% end %>

      <%= link_to edit_admin_event_path(event), class: "p-2 border-y border-x-0 border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: "編集" do %>
        <%= icon(:edit, class: "w-4 h-4") %>
      <% end %>

      <%= button_to [:admin, event], method: :delete, class: "p-2 rounded-r-xl border border-gray-200 bg-white text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all shadow-sm", data: { turbo_confirm: "イベントを削除してもよろしいですか？この操作は取り消せません。" }, title: "削除" do %>
        <%= icon(:trash, class: "w-4 h-4") %>
      <% end %>
    </div>
  </td>
</tr>