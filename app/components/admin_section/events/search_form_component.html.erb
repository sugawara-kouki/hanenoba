<div class="mb-12 p-10 bg-white rounded-[3rem] border border-gray-100 shadow-xl shadow-gray-900/[0.02] ring-1 ring-gray-900/5">
  <%= form_with url: admin_events_path, method: :get, local: true, class: "space-y-10" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <%# キーワード %>
      <div class="space-y-2">
        <%= f.label :q, t('events.index.search.keyword'), class: "text-[10px] font-bold text-gray-400 uppercase tracking-widest ml-1" %>
        <%= f.text_field :q, value: params[:q], placeholder: t('common.search.placeholders.keyword'), 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm transition-all h-12" %>
      </div>

      <%# 開催日 %>
      <div class="space-y-2">
        <%= f.label :date, t('events.index.search.date'), class: "text-[10px] font-bold text-gray-400 uppercase tracking-widest ml-1" %>
        <%= f.date_field :date, value: params[:date], 
          class: "block w-full rounded-xl border-0 pl-4 pr-10 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm transition-all h-12" %>
      </div>

      <%# ステータス %>
      <div class="space-y-2">
        <%= f.label :status, t('events.index.search.status'), class: "text-[10px] font-bold text-gray-400 uppercase tracking-widest ml-1" %>
        <div class="relative">
          <%= f.select :status, Event.statuses.keys.map { |k| [Event.new(status: k).status_ja, k] }, { include_blank: "すべて", selected: params[:status] }, 
              class: "block w-full appearance-none rounded-xl border-0 pl-4 pr-10 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm transition-all h-12" %>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>

      <%# 残在庫数 %>
      <div class="space-y-2">
        <%= f.label :capacity, t('events.index.search.capacity'), class: "text-[10px] font-bold text-gray-400 uppercase tracking-widest ml-1" %>
        <div class="relative">
          <%= f.number_field :capacity, value: params[:capacity], min: 1, 
              class: "block w-full rounded-xl border-0 pl-4 pr-12 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm transition-all h-12" %>
          <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
            <span class="text-[10px] font-bold text-gray-400"><%= t('events.index.search.capacity_suffix') %></span>
          </div>
        </div>
      </div>
    </div>

    <%# ボタン集 %>
    <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-50">
      <%= link_to admin_events_path, class: "px-8 py-3.5 rounded-2xl border border-gray-200 text-gray-500 font-bold hover:bg-gray-50 transition-all text-sm flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <%= t('events.index.search.clear') %>
      <% end %>
      <%= f.submit t('events.index.search.submit'), class: "min-w-[160px] bg-indigo-600 hover:bg-indigo-500 text-white font-black py-3.5 px-8 rounded-2xl transition-all active:scale-95 cursor-pointer shadow-xl shadow-indigo-100 text-sm uppercase tracking-widest" %>
    </div>
  <% end %>
</div>