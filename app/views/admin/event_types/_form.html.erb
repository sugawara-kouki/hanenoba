<%= form_with(model: [:admin, event_type], class: "space-y-8") do |form| %>
  <%= render AdminUi::FormErrorsComponent.new(model: event_type) %>

  <%# 基本設定 %>
  <%= render AdminUi::CardComponent.new(title: t('admin.views.event_types.form.title')) do %>
    <p class="mt-1 text-xs text-gray-500 font-medium mb-6"><%= t('admin.views.event_types.form.subtitle') %></p>
    
    <div>
      <%= form.label :name %>
      <%= form.text_field :name, placeholder: t('admin.views.event_types.form.placeholder') %>
    </div>
  <% end %>

  <%# アクションボタン %>
  <div class="flex items-center justify-end space-x-4">
    <%= link_to t('common.actions.cancel'), admin_event_types_path, class: "text-sm font-bold text-gray-500 hover:text-gray-700 px-4 py-2" %>
    <%= form.submit t('admin.views.event_types.form.save'), 
        class: "inline-flex items-center rounded-xl bg-indigo-600 px-8 py-4 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all active:scale-95 cursor-pointer" %>
  </div>
<% end %>
