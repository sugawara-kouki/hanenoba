<% content_for :title, "Showing event type" %>

<div class="md:w-2/3 w-full">


  <h1 class="font-bold text-4xl">Showing event type</h1>

  <%= render @event_type %>

  <%= link_to "Edit this event type", edit_admin_event_type_path(@event_type), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 inline-block font-medium" %>
  <%= link_to "Back to event types", admin_event_types_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 inline-block font-medium" %>
  <%= button_to "Destroy this event type", [:admin, @event_type], method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>
