<% content_for :title, "New Event Type | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [
    { name: "種別設定", link: admin_event_types_path },
    { name: "新規種別" }
  ] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <div class="flex items-center space-x-2 text-indigo-600 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest">Metadata Creator</span>
      </div>
      <h1 class="text-3xl font-black text-gray-900 leading-tight">新規イベント種別</h1>
      <p class="mt-2 text-sm text-gray-500">新しいイベントカテゴリーを定義し、コミュニティの幅を広げましょう。</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none space-x-3">
      <%= link_to admin_event_types_path, class: "inline-flex items-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
        キャンセル
      <% end %>
    </div>
  </div>

  <%= render "form", event_type: @event_type %>
</div>
