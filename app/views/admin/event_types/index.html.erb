<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render AdminUi::Layout::BreadcrumbsComponent.new(breadcrumbs: [{ name: t('admin.views.event_types.index.breadcrumb') }]) %>

  <%= render AdminUi::Layout::PageHeaderComponent.new(
        title: t('admin.views.event_types.index.title'),
        subtitle: t('admin.views.event_types.index.subtitle')
      ) do |c| %>
    <% c.with_action do %>
      <%= link_to new_admin_event_type_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <%= icon(:plus, class: "h-5 w-5 mr-2") %>
        <%= t('admin.views.event_types.index.new') %>
      <% end %>
    <% end %>
  <% end %>

  <div class="mt-8 flow-root">
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
              <%= sort_link "name", "種別情報" %>
            </th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest w-40">
              <%= sort_link "created_at", "登録日" %>
            </th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right w-28">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% if @event_types.any? %>
            <% @event_types.each do |event_type| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                 <td class="py-5 pl-8 pr-3">
                  <div class="flex items-center space-x-3">
                    <div class="h-9 w-9 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-500 shadow-sm border border-indigo-100">
                      <%= icon(:tag, class: "h-4 w-4") %>
                    </div>
                    <span class="text-base font-bold text-gray-900"><%= event_type.name %></span>
                  </div>
                </td>
                 <td class="whitespace-nowrap px-3 py-5">
                  <div class="tabular-nums text-sm font-semibold text-gray-900">
                    <%= l(event_type.created_at, format: :dot_date) %>
                  </div>
                </td>
                <td class="whitespace-nowrap py-5 pl-3 pr-8 text-right font-medium">
                  <div class="flex items-center justify-end -space-x-px">
                    <%= link_to edit_admin_event_type_path(event_type), class: "p-2 rounded-l-xl border border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: "編集" do %>
                      <%= icon(:edit, class: "h-4 w-4") %>
                    <% end %>

                    <%= button_to [:admin, event_type], method: :delete, class: "p-2 rounded-r-xl border border-gray-200 bg-white text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all shadow-sm", data: { turbo_confirm: "種別「#{event_type.name}」を削除してもよろしいですか？\nこの種別を設定しているイベントがある場合は削除できません。" }, title: "削除" do %>
                        <%= icon(:trash, class: "w-4 h-4") %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-8 py-20 text-center text-sm text-gray-400 bg-gray-50/30">
                <div class="flex flex-col items-center justify-center">
                  <%= icon(:tag, class: "h-12 w-12 text-gray-200 mb-4") %>
                  <p class="font-bold">種別が登録されていません。</p>
                  <p class="text-xs mt-1">新規作成ボタンから追加してください。</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
