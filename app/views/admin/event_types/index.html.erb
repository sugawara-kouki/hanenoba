<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [{ name: "種別設定" }] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-black text-gray-900 leading-tight">イベント種別設定</h1>
      <p class="mt-2 text-sm text-gray-500 font-medium tracking-tight">イベントを分類するためのカテゴリーと、表示テーマカラーを設定します。</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_admin_event_type_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        新規種別を作成
      <% end %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="overflow-hidden shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= sort_link "name", "種別名" %></th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest font-mono"><%= sort_link "created_at", "登録日" %></th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% if @event_types.any? %>
            <% @event_types.each do |event_type| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="whitespace-nowrap py-6 pl-8 pr-3 text-sm font-bold text-gray-900">
                  <div class="flex items-center space-x-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                    <span><%= event_type.name %></span>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-900 font-bold font-mono">
                  <%= event_type.created_at.strftime("%Y/%m/%d") %>
                </td>
                <td class="relative whitespace-nowrap py-6 pl-3 pr-8 text-right font-medium">
                  <div class="flex items-center justify-end space-x-2">
                    <%= link_to edit_admin_event_type_path(event_type), class: "inline-flex items-center px-4 py-2.5 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-gray-900 transition-all shadow-sm text-xs font-bold", title: "編集" do %>
                      編集
                    <% end %>

                    <%= button_to [:admin, event_type], method: :delete, class: "inline-flex items-center px-2.5 py-2.5 rounded-xl text-red-300 hover:text-red-600 hover:bg-red-50 transition-all", data: { turbo_confirm: "種別「#{event_type.name}」を削除してもよろしいですか？\nこの種別を設定しているイベントがある場合は削除できません。" }, title: "削除" do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-8 py-20 text-center text-sm text-gray-400 bg-gray-50/30">
                <div class="flex flex-col items-center justify-center">
                  <svg class="h-12 w-12 text-gray-200 mb-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                  </svg>
                  <p class="font-bold">種別が登録されていません。</p>
                  <p class="text-xs mt-1">新規作成ボタンから追加してください。</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
