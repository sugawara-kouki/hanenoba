<% content_for :title, "Edit Event Type | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [
    { name: "種別設定", link: admin_event_types_path },
    { name: "種別編集 (#{@event_type.name})" }
  ] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <div class="flex items-center space-x-2 text-indigo-600 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest">Metadata Editor</span>
      </div>
      <h1 class="text-3xl font-black text-gray-900 leading-tight">イベント種別を編集</h1>
      <p class="mt-2 text-sm text-gray-500">カテゴリーの名前やテーマカラーを調整します。</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none space-x-3">
      <%= link_to admin_event_types_path, class: "inline-flex items-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
        キャンセル
      <% end %>
    </div>
  </div>

  <%= render "form", event_type: @event_type %>
</div>
