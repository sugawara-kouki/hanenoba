<% content_for :title, "Edit Event Type | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render AdminUi::Layout::BreadcrumbsComponent.new(breadcrumbs: [
    { name: "種別設定", link: admin_event_types_path },
    { name: "種別編集 (#{@event_type.name})" }
  ]) %>

  <%= render AdminUi::Layout::PageHeaderComponent.new(
        title: t('admin.views.event_types.edit.title'),
        subtitle: t('admin.views.event_types.edit.subtitle')
      ) do |c| %>
    <% c.with_prepend do %>
      <div class="flex items-center space-x-2 text-indigo-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest">Metadata Editor</span>
      </div>
    <% end %>
    <% c.with_action do %>
      <%= link_to admin_event_types_path, class: "inline-flex items-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
        キャンセル
      <% end %>
    <% end %>
  <% end %>

  <%= render "form", event_type: @event_type %>
</div>
