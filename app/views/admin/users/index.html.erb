<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [{ name: "ユーザー管理" }] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-black text-gray-900 leading-tight"><%= t('admin.views.users.index.title') %></h1>
      <p class="mt-2 text-sm text-gray-500 font-medium tracking-tight"><%= t('admin.views.users.index.subtitle') %></p>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= sort_link "name", "ユーザープロフィール" %></th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= sort_link "email", "メールアドレス" %></th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest font-mono"><%= sort_link "created_at", "登録日" %></th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= sort_link "approved", "状態" %></th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50/30 transition-colors">
              <td class="whitespace-nowrap py-6 pl-8 pr-3 text-sm">
                <div class="flex items-center">
                  <div class="h-11 w-11 flex-shrink-0">
                    <%= image_tag user.image || "https://ui-avatars.com/api/?name=#{user.name}&background=random", 
                        class: "h-11 w-11 rounded-full object-cover ring-2 ring-gray-100 shadow-sm", 
                        alt: user.name %>
                  </div>
                  <div class="ml-4">
                    <div class="font-bold text-gray-900 text-base"><%= user.name || "名称未設定" %></div>
                    <div class="mt-0.5 text-gray-400 text-[10px] font-bold uppercase tracking-wider font-mono">UID: <%= user.uid %></div>
                  </div>
                </div>
              </td>
              <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-500 font-medium">
                <%= user.email.presence || "---" %>
              </td>
              <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-900 font-bold font-mono">
                <%= user.created_at.strftime("%Y/%m/%d") %>
              </td>
              <td class="whitespace-nowrap px-3 py-6 text-sm">
                <% if user.approved? %>
                  <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-[10px] font-black text-indigo-700 ring-1 ring-inset ring-indigo-600/20 uppercase tracking-wider">
                    承認済
                  </span>
                <% else %>
                  <span class="inline-flex items-center rounded-md bg-yellow-50 px-2.5 py-1 text-[10px] font-black text-yellow-800 ring-1 ring-inset ring-yellow-600/20 uppercase tracking-wider">
                    承認待
                  </span>
                <% end %>
              </td>
              <td class="relative whitespace-nowrap py-6 pl-3 pr-8 text-right font-medium">
                <div class="flex justify-end space-x-2 items-center">
                  <% if Rails.env.development? %>
                    <%= button_to impersonate_admin_user_path(user), 
                        method: :post, 
                        class: "inline-flex items-center rounded-xl bg-amber-500 px-4 py-2.5 text-xs font-bold text-white shadow-xl shadow-amber-100 hover:bg-amber-400 transition-all",
                        data: { turbo_confirm: "#{user.name || user.email} #{t('admin.views.users.index.impersonate_confirm')}" } do %>
                      <%= t('admin.views.users.index.impersonate') %>
                    <% end %>
                  <% end %>

                  <%= button_to user.approved? ? t('admin.views.users.index.suspend') : t('admin.views.users.index.approve'), admin_user_path(user), 
                      method: :patch, 
                      class: user.approved? ? 
                        "inline-flex items-center rounded-xl bg-white border border-gray-200 text-red-500 px-4 py-2.5 text-xs font-bold shadow-sm hover:bg-red-50 hover:border-red-100 transition-all" : 
                        "inline-flex items-center rounded-xl bg-indigo-600 px-4 py-2.5 text-xs font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all",
                      data: { turbo_confirm: "#{user.name} を#{user.approved? ? '停止' : '承認'}しますか？" } %>
                  
                  <%= button_to admin_user_path(user), 
                      method: :delete, 
                      class: "p-2.5 text-gray-300 hover:text-red-600 transition-colors",
                      data: { turbo_confirm: "ユーザー「#{user.name}」を完全に削除しますか？\nこの操作は取り消せません。" }, title: "完全削除" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
