<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render AdminUI::Layout::BreadcrumbsComponent.new(breadcrumbs: [{ name: "管理者ユーザー管理" }]) %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-bold text-gray-900 leading-tight"><%= t('admin.views.admins.index.title') %></h1>
      <p class="mt-2 text-sm text-gray-500 font-medium tracking-tight"><%= t('admin.views.admins.index.subtitle') %></p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_admin_admin_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t('admin.views.admins.index.new') %>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
              <%= sort_link "email", "管理者情報" %>
            </th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest w-40">
              <%= sort_link "created_at", "登録日" %>
            </th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right w-28">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @admins.each do |admin_user| %>
            <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="py-5 pl-8 pr-3">
                  <div class="flex items-center">
                    <div class="h-10 w-10 rounded-xl bg-indigo-500 flex items-center justify-center text-white text-xs font-bold shadow-lg shadow-indigo-500/20 mr-4">
                      <%= admin_user.email[0].upcase %>
                    </div>
                    <div class="flex flex-col">
                      <div class="flex items-center space-x-2">
                        <span class="text-base font-bold text-gray-900 tabular-nums"><%= admin_user.email %></span>
                        <% if admin_user == current_admin %>
                          <span class="inline-flex items-center rounded-md bg-indigo-50 px-1.5 py-0.5 text-[10px] font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10 uppercase tracking-tighter">
                            YOU
                          </span>
                        <% end %>
                      </div>
                      <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5">Administrator</div>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-5">
                  <div class="tabular-nums text-sm font-semibold text-gray-900">
                    <%= admin_user.created_at.strftime("%Y/%m/%d") %>
                  </div>
                </td>
                <td class="whitespace-nowrap py-5 pl-3 pr-8 text-right font-medium">
                  <div class="flex justify-end -space-x-px">
                    <%= link_to edit_admin_admin_path(admin_user), class: "p-2 rounded-l-xl border border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: "編集" do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>
                    
                    <% if admin_user != current_admin %>
                      <%= button_to admin_admin_path(admin_user), 
                          method: :delete, 
                          class: "p-2 rounded-r-xl border border-gray-200 bg-white text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all shadow-sm",
                          data: { turbo_confirm: "管理者「#{admin_user.email}」を削除しますか？" }, title: "削除" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      <% end %>
                    <% else %>
                      <div class="p-2 rounded-r-xl border border-gray-200 bg-gray-50/50 text-gray-300 shadow-sm cursor-not-allowed">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
