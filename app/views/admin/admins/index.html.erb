<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [{ name: "管理者ユーザー管理" }] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-black text-gray-900 leading-tight">管理者ユーザー管理</h1>
      <p class="mt-2 text-sm text-gray-500 font-medium tracking-tight">システムの管理権限を持つユーザーの一覧と管理を行います。</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_admin_admin_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        新規管理者を作成
      <% end %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="overflow-hidden shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">メールアドレス</th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest font-mono">登録日</th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @admins.each do |admin_user| %>
            <tr class="hover:bg-gray-50/30 transition-colors">
              <td class="whitespace-nowrap py-6 pl-8 pr-3 text-sm">
                <div class="flex items-center">
                  <div class="h-9 w-9 rounded-xl bg-indigo-500 flex items-center justify-center text-white text-xs font-black shadow-lg shadow-indigo-500/20 mr-4">
                    <%= admin_user.email[0].upcase %>
                  </div>
                  <div class="flex flex-col">
                    <div class="flex items-center space-x-2">
                      <span class="font-bold text-gray-900 font-mono"><%= admin_user.email %></span>
                      <% if admin_user == current_admin %>
                        <span class="inline-flex items-center rounded-md bg-indigo-50 px-1.5 py-0.5 text-[10px] font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
                          あなた
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>
              <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-900 font-bold font-mono">
                <%= admin_user.created_at.strftime("%Y/%m/%d") %>
              </td>
              <td class="relative whitespace-nowrap py-6 pl-3 pr-8 text-right font-medium">
                <div class="flex justify-end space-x-2 items-center">
                  <%= link_to edit_admin_admin_path(admin_user), class: "inline-flex items-center px-4 py-2.5 rounded-xl bg-white border border-gray-200 text-gray-700 text-xs font-bold shadow-sm hover:bg-gray-50 transition-all" do %>
                    編集
                  <% end %>
                  
                  <% unless admin_user == current_admin %>
                    <%= button_to admin_admin_path(admin_user), 
                        method: :delete, 
                        class: "p-2.5 text-gray-300 hover:text-red-600 transition-colors",
                        data: { turbo_confirm: "管理者「#{admin_user.email}」を削除しますか？" }, title: "削除" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
