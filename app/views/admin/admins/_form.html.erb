<%= form_with(model: [:admin, admin], class: "space-y-8") do |f| %>
  <%= render AdminUi::FormErrorsComponent.new(model: admin) %>

  <%= render AdminUi::CardComponent.new(title: t('admin.views.admins.index.title')) do %>
    <div class="grid grid-cols-1 gap-y-8">
      <div>
        <%= f.label :email %>
        <%= f.email_field :email, placeholder: t('common.forms.placeholders.email') %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <%= f.label :password %>
          <%= f.password_field :password, placeholder: t('common.forms.placeholders.password') %>
          <% if f.object.persisted? %>
            <p class="mt-2 text-[10px] text-gray-400 font-bold"><%= t('common.forms.hints.password_change') %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation %>
        </div>
      </div>
    </div>
  <% end %>

    <div class="pt-6 flex flex-col sm:flex-row items-center gap-4">
      <%= f.submit class: "w-full sm:w-auto inline-flex justify-center items-center rounded-2xl bg-indigo-600 px-10 py-4 text-sm font-black text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-600 active:scale-95 cursor-pointer" %>
      <%= link_to t('common.actions.cancel'), admin_admins_path, class: "w-full sm:w-auto inline-flex justify-center items-center rounded-2xl bg-white border border-gray-200 px-10 py-4 text-sm font-bold text-gray-500 hover:bg-gray-50 hover:text-gray-900 transition-all" %>
    </div>
  </div>
<% end %>
