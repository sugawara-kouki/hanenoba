<% content_for :title, "Edit Event | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render AdminUI::Layout::BreadcrumbsComponent.new(breadcrumbs: [
    { name: t('admin.views.events.index.breadcrumb'), link: admin_events_path },
    { name: @event.title, link: admin_event_path(@event) },
    { name: t('admin.views.events.edit.breadcrumb') }
  ]) %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <div class="flex items-center space-x-2 text-indigo-600 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest"><%= t('admin.views.events.form.editor') %></span>
      </div>
      <h1 class="text-3xl font-black text-gray-900 leading-tight"><%= t('admin.views.events.edit.title') %></h1>
      <p class="mt-2 text-sm text-gray-500"><%= t('admin.views.events.edit.subtitle') %></p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none space-x-3">
      <%= link_to admin_events_path, class: "inline-flex items-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
        <%= t('common.actions.cancel') %>
      <% end %>
    </div>
  </div>

  <%= render "form", event: @event %>
</div>
