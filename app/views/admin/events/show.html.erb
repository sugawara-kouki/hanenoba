<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto" data-controller="modal" data-action="keydown@window->modal#closeWithEsc">
  <%= render AdminUi::Layout::BreadcrumbsComponent.new(breadcrumbs: [
    { name: t('admin.views.events.index.breadcrumb'), link: admin_events_path },
    { name: @event.title }
  ]) %>

  <%= render AdminUi::Layout::PageHeaderComponent.new(
        title: @event.title
      ) do |c| %>
    <% c.with_prepend do %>
      <div class="flex items-center space-x-3 text-indigo-600">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10">
          <%= @event.event_type.name %>
        </span>
        <div class="flex items-center space-x-1.5 text-indigo-600">
          <%= icon(:document_text, class: "h-4 w-4") %>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600/60 font-mono">ID: <%= @event.id %></span>
        </div>
      </div>
    <% end %>
    <% c.with_action do %>
      <div class="flex items-center space-x-3">
        <button type="button" 
                data-action="click->modal#open"
                class="inline-flex items-center rounded-xl bg-indigo-50 px-5 py-3 text-sm font-bold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-100 hover:bg-indigo-100 transition-all group cursor-pointer">
          <%= icon(:eye, class: "h-4 w-4 mr-2 group-hover:scale-110 transition-transform") %>
          <%= t('admin.views.events.show.view_public_page') %>
          <%= icon(:sparkles, class: "h-3 w-3 ml-2 opacity-50") %>
        </button>

        <%= link_to edit_admin_event_path(@event), class: "inline-flex items-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
          <%= icon(:edit, class: "h-4 w-4 mr-2") %>
          <%= t('admin.views.events.show.edit_event') %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ... (existing content continues) ... %>

  <%# プレビューモーダル本体 %>
  <div data-modal-target="container" 
       data-action="click->modal#closeBackground"
       class="hidden fixed inset-0 z-[100] items-center justify-center p-4 sm:p-10 bg-gray-900/90 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="relative w-full h-full max-w-6xl bg-white rounded-[2.5rem] shadow-2xl flex flex-col overflow-hidden ring-1 ring-white/20 animate-in zoom-in-95 duration-300">
      <%# モーダルヘッダー %>
      <div class="px-8 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50">
        <div class="flex items-center space-x-4">
          <div class="bg-indigo-600 p-2 rounded-xl">
            <%= icon(:eye, class: "h-5 w-5 text-white") %>
          </div>
          <div>
            <h3 class="text-lg font-black text-gray-900 leading-none"><%= t('admin.views.events.show.preview_mode') %></h3>
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1.5">Live Public View</p>
          </div>
        </div>
        <button type="button" 
                data-action="click->modal#close"
                class="p-2 rounded-xl hover:bg-gray-200 text-gray-400 hover:text-gray-900 transition-all cursor-pointer">
          <%= icon(:x_mark, class: "h-6 w-6") %>
        </button>
      </div>
      
      <%# プレビュー本体 (Iframe) %>
      <div class="flex-grow bg-gray-100 relative">
        <div class="absolute inset-0 flex items-center justify-center -z-10">
          <div class="animate-pulse flex flex-col items-center">
            <%= icon(:cog, class: "h-12 w-12 text-gray-200 animate-spin-slow mb-4") %>
            <p class="text-gray-400 font-bold text-sm">Loading Preview...</p>
          </div>
        </div>
        <iframe src="<%= event_path(@event, preview: true) %>" class="w-full h-full border-none shadow-inner"></iframe>
      </div>

      <%# モーダルフッター %>
      <div class="px-8 py-4 bg-gray-50 border-t border-gray-100 flex justify-center">
        <p class="text-[10px] text-gray-400 font-black uppercase tracking-[0.3em]">
          <%= t('admin.views.events.show.preview_description') %>
        </p>
      </div>
    </div>
  </div>
</div>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3 mb-16">
    <%# 基本情報カード %>
    <div class="lg:col-span-2 space-y-8">
      <%= render AdminUi::CardComponent.new(title: t('admin.views.events.show.basic_info'), icon: :info) do |card| %>
        <% card.with_header_action do %>
          <%= render AdminUi::BadgeComponent.new(status: @event.status) %>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-10 gap-x-8">
          <% if @event.image.attached? %>
            <div class="sm:col-span-2 overflow-hidden rounded-2xl ring-1 ring-gray-900/10 shadow-sm bg-gray-50 aspect-[3/1]">
              <%= image_tag @event.image.variant(resize_to_limit: [1200, 400]), class: "w-full h-full object-cover" %>
            </div>
          <% end %>
          <div class="group">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono"><%= t('admin.views.events.show.held_at') %></label>
            <div class="flex items-center space-x-3">
              <div class="bg-indigo-50 p-2 rounded-lg text-indigo-600">
                <%= icon(:calendar) %>
              </div>
              <p class="text-xl font-bold text-gray-900 pb-1 border-b-2 border-transparent group-hover:border-indigo-100 transition-all"><%= l(@event.held_at, format: :long) %></p>
            </div>
          </div>
          <div class="group">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono"><%= t('admin.views.events.show.location') %></label>
            <div class="flex items-center space-x-3">
              <div class="bg-emerald-50 p-2 rounded-lg text-emerald-600">
                <%= icon(:location) %>
              </div>
              <p class="text-xl font-bold text-gray-900 pb-1 border-b-2 border-transparent group-hover:border-emerald-100 transition-all"><%= @event.location %></p>
            </div>
          </div>
          <div class="group sm:col-span-2">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono"><%= t('admin.views.events.show.capacity') %></label>
            <div class="flex items-center space-x-3">
              <div class="bg-amber-50 p-2 rounded-lg text-amber-600">
                <%= icon(:users) %>
              </div>
              <p class="text-xl font-extrabold text-gray-900"><%= @event.capacity %><span class="text-sm font-bold text-gray-400 ml-1">名</span></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# 申込状況の概要 %>
    <div class="lg:col-span-1">
      <div class="bg-gray-900 rounded-3xl shadow-xl shadow-gray-200/50 p-8 text-white h-full flex flex-col justify-between">
        <div>
          <div class="flex items-center space-x-2 opacity-50 mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em]"><%= t('admin.views.events.show.booking_summary') %></h3>
          </div>
          <div class="flex items-baseline space-x-2 mb-4">
            <span class="text-7xl font-black tracking-tighter"><%= @event.bookings.count %></span>
            <span class="text-gray-500 font-bold text-2xl tracking-tight">/ <%= @event.capacity %></span>
          </div>
          <p class="text-gray-400 text-sm font-medium leading-relaxed"><%= t('admin.views.events.show.booking_full_percent', percent: @event.occupancy_rate) %></p>
        </div>
        
        <div class="mt-8">
          <div class="w-full bg-gray-800 rounded-full h-3 overflow-hidden">
            <div class="bg-indigo-500 h-full rounded-full shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all duration-1000" style="width: <%= [@event.occupancy_rate, 100].min %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# 参加者一覧テーブル %>
  <div class="flow-root">
    <div class="sm:flex sm:items-center mb-8">
      <div class="sm:flex-auto">
        <div class="flex items-center space-x-2 text-gray-400 mb-1">
          <%= icon(:users, class: "h-4 w-4") %>
          <span class="text-[10px] font-black uppercase tracking-[0.2em]">Participants List</span>
        </div>
        <h2 class="text-2xl font-black text-gray-900 tracking-tight"><%= t('admin.views.events.show.participants_list') %></h2>
        <p class="mt-1 text-sm text-gray-500 font-medium"><%= t('admin.views.events.show.participants_subtitle') %></p>
      </div>
    </div>
    
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= t('admin.views.events.show.table.user') %></th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest"><%= t('admin.views.events.show.table.applied_at') %></th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% if @bookings.any? %>
            <% @bookings.each do |booking| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="whitespace-nowrap py-6 pl-8 pr-3 text-sm">
                  <div class="flex items-center">
                    <div class="h-10 w-10 flex-shrink-0">
                      <%= image_tag booking.user.image || "https://ui-avatars.com/api/?name=#{booking.user.name}&background=random", 
                          class: "h-10 w-10 rounded-full object-cover ring-2 ring-gray-100 shadow-sm", 
                          alt: booking.user.name %>
                    </div>
                    <div class="ml-4">
                      <div class="font-bold text-gray-900 text-base"><%= booking.user.name || "名称未設定" %></div>
                      <div class="text-[10px] text-gray-400 font-mono font-bold tracking-tight">UID: <%= booking.user.uid %></div>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-500 font-medium">
                  <%= l(booking.created_at, format: :long) %>
                </td>
                <td class="relative whitespace-nowrap py-6 pl-3 pr-8 text-right font-medium">
                  <%= button_to admin_booking_path(booking), 
                      method: :delete, 
                      class: "inline-flex items-center rounded-xl bg-white px-4 py-2 text-xs font-bold text-red-500 shadow-sm ring-1 ring-inset ring-red-100 hover:bg-red-50 transition-all",
                      data: { turbo_confirm: t('admin.views.events.show.confirm_cancel_booking', name: booking.user.name) } do %>
                    <%= t('admin.views.events.show.cancel_booking') %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-8 py-20 text-center text-sm text-gray-400 bg-gray-50/30">
                <div class="flex flex-col items-center justify-center">
                  <%= icon(:users, class: "h-12 w-12 text-gray-200 mb-4") %>
                  <p class="font-bold"><%= t('admin.views.events.show.no_participants') %></p>
                  <p class="text-xs mt-1"><%= t('admin.views.events.show.recruit_participants') %></p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
