<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [
    { name: "イベント一覧", link: admin_events_path },
    { name: @event.title }
  ] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <div class="flex items-center space-x-3 mb-2">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10">
          <%= @event.event_type.name %>
        </span>
        <div class="flex items-center space-x-1.5 text-indigo-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600/60 font-mono">ID: <%= @event.id %></span>
        </div>
      </div>
      <h1 class="text-4xl font-black text-gray-900 leading-tight tracking-tight"><%= @event.title %></h1>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none space-x-3">
      <%= link_to edit_admin_event_path(@event), class: "inline-flex items-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-all" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        イベントを編集
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3 mb-16">
    <%# 基本情報カード %>
    <div class="lg:col-span-2 space-y-8">
      <div class="bg-white rounded-3xl shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
        <div class="px-8 py-6 border-b border-gray-50 bg-gray-50/50 flex items-center justify-between">
          <div class="flex items-center space-x-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-base font-bold leading-7 text-gray-900">基本情報</h3>
          </div>
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold ring-1 ring-inset <%= @event.published? ? 'bg-green-50 text-green-700 ring-green-600/20' : 'bg-yellow-50 text-yellow-700 ring-yellow-600/20' %>">
            <%= @event.status_ja %>
          </span>
        </div>
        <div class="px-8 py-10 grid grid-cols-1 sm:grid-cols-2 gap-y-10 gap-x-8">
          <div class="group">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono">開催日時 / HELD AT</label>
            <div class="flex items-center space-x-3">
              <div class="bg-indigo-50 p-2 rounded-lg text-indigo-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <p class="text-xl font-bold text-gray-900 pb-1 border-b-2 border-transparent group-hover:border-indigo-100 transition-all"><%= @event.held_at.strftime("%Y年 %m月 %d日 %H:%M") %></p>
            </div>
          </div>
          <div class="group">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono">開催予定場所 / LOCATION</label>
            <div class="flex items-center space-x-3">
              <div class="bg-emerald-50 p-2 rounded-lg text-emerald-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <p class="text-xl font-bold text-gray-900 pb-1 border-b-2 border-transparent group-hover:border-emerald-100 transition-all"><%= @event.location %></p>
            </div>
          </div>
          <div class="group sm:col-span-2">
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 font-mono">募集定員</label>
            <div class="flex items-center space-x-3">
              <div class="bg-amber-50 p-2 rounded-lg text-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <p class="text-xl font-extrabold text-gray-900"><%= @event.capacity %><span class="text-sm font-bold text-gray-400 ml-1">名</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# 申込状況の概要 %>
    <div class="lg:col-span-1">
      <div class="bg-gray-900 rounded-3xl shadow-xl shadow-gray-200/50 p-8 text-white h-full flex flex-col justify-between">
        <div>
          <div class="flex items-center space-x-2 opacity-50 mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em]">申込状況概要</h3>
          </div>
          <div class="flex items-baseline space-x-2 mb-4">
            <span class="text-7xl font-black tracking-tighter"><%= @event.bookings.count %></span>
            <span class="text-gray-500 font-bold text-2xl tracking-tight">/ <%= @event.capacity %></span>
          </div>
          <p class="text-gray-400 text-sm font-medium leading-relaxed">現時点で定員の <span class="text-white font-bold"><%= (@event.bookings.count.to_f / @event.capacity * 100).round %>%</span> が埋まっています。</p>
        </div>
        
        <div class="mt-8">
          <div class="w-full bg-gray-800 rounded-full h-3 overflow-hidden">
            <div class="bg-indigo-500 h-full rounded-full shadow-[0_0_20px_rgba(99,102,241,0.5)] transition-all duration-1000" style="width: <%= [@event.bookings.count.to_f / @event.capacity * 100, 100].min %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# 参加者一覧テーブル %>
  <div class="flow-root">
    <div class="sm:flex sm:items-center mb-8">
      <div class="sm:flex-auto">
        <div class="flex items-center space-x-2 text-gray-400 mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span class="text-[10px] font-black uppercase tracking-[0.2em]">Participants List</span>
        </div>
        <h2 class="text-2xl font-black text-gray-900 tracking-tight">参加申込者一覧</h2>
        <p class="mt-1 text-sm text-gray-500 font-medium">現在、このイベントに申し込んでいる全てのユーザーです。</p>
      </div>
    </div>
    
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">参加ユーザー</th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">申込日時</th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% if @bookings.any? %>
            <% @bookings.each do |booking| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="whitespace-nowrap py-6 pl-8 pr-3 text-sm">
                  <div class="flex items-center">
                    <div class="h-10 w-10 flex-shrink-0">
                      <%= image_tag booking.user.image || "https://ui-avatars.com/api/?name=#{booking.user.name}&background=random", 
                          class: "h-10 w-10 rounded-full object-cover ring-2 ring-gray-100 shadow-sm", 
                          alt: booking.user.name %>
                    </div>
                    <div class="ml-4">
                      <div class="font-bold text-gray-900 text-base"><%= booking.user.name || "名称未設定" %></div>
                      <div class="text-[10px] text-gray-400 font-mono font-bold tracking-tight">UID: <%= booking.user.uid %></div>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-6 text-sm text-gray-500 font-medium">
                  <%= booking.created_at.strftime("%Y/%m/%d %H:%M") %>
                </td>
                <td class="relative whitespace-nowrap py-6 pl-3 pr-8 text-right font-medium">
                  <%= button_to admin_booking_path(booking), 
                      method: :delete, 
                      class: "inline-flex items-center rounded-xl bg-white px-4 py-2 text-xs font-bold text-red-500 shadow-sm ring-1 ring-inset ring-red-100 hover:bg-red-50 transition-all",
                      data: { turbo_confirm: "「#{booking.user.name}」の申し込みを取り消しますか？\nこの操作は元に戻せません。" } do %>
                    申込を取り消す
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-8 py-20 text-center text-sm text-gray-400 bg-gray-50/30">
                <div class="flex flex-col items-center justify-center">
                  <svg class="h-12 w-12 text-gray-200 mb-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                  <p class="font-bold">申込者はまだいません。</p>
                  <p class="text-xs mt-1">公開して参加者を募りましょう。</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
