<%= form_with(model: [:admin, event], class: "space-y-8") do |form| %>
  <% if event.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-xl mb-8">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-bold text-red-800">入力内容に<%= event.errors.count %>件のエラーがあります</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% event.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# セクション1: 基本情報 %>
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-3xl overflow-hidden">
    <div class="px-8 py-6 border-b border-gray-50 bg-gray-50/50">
      <h3 class="text-base font-bold leading-7 text-gray-900">1. 基本情報</h3>
      <p class="mt-1 text-xs text-gray-500 font-medium lowercase tracking-wider">イベントのタイトルと種別を設定します。</p>
    </div>
    <div class="p-8 space-y-6">
      <div>
        <%= form.label :title, "イベント名", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= form.text_field :title, placeholder: "例：春の交流BBQパーティ", 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
      </div>

      <div>
        <%= form.label :event_type_id, "イベント種別", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= form.collection_select :event_type_id, EventType.all, :id, :name, { prompt: "種別を選択してください" }, 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
      </div>
    </div>
  </div>

  <%# セクション2: 開催日時・場所 %>
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-3xl overflow-hidden">
    <div class="px-8 py-6 border-b border-gray-50 bg-gray-50/50">
      <h3 class="text-base font-bold leading-7 text-gray-900">2. 開催日時・場所</h3>
      <p class="mt-1 text-xs text-gray-500 font-medium lowercase tracking-wider">どこで、いつ開催するか、何人まで参加できるかを設定します。</p>
    </div>
    <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
      <div class="md:col-span-2">
        <%= form.label :location, "開催場所", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= form.text_field :location, placeholder: "例：ハネノバ共有スペース", 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
      </div>

      <div>
        <%= form.label :held_at, "開催日時", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= form.datetime_field :held_at, 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
      </div>

      <div>
        <%= form.label :capacity, "定員（名）", class: "block text-sm font-bold text-gray-700 mb-2" %>
        <%= form.number_field :capacity, min: 1, 
            class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
      </div>
    </div>
  </div>

  <%# セクション3: 公開設定 %>
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-3xl overflow-hidden">
    <div class="px-8 py-6 border-b border-gray-50 bg-gray-50/50">
      <h3 class="text-base font-bold leading-7 text-gray-900">3. 公開設定</h3>
      <p class="mt-1 text-xs text-gray-500 font-medium lowercase tracking-wider">イベントの公開状態を選択します。</p>
    </div>
    <div class="p-8">
      <%= form.label :status, "ステータス", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%# カスタムラジオ風の選択肢に作り込みたいところですが、まずは使いやすいセレクトボックスで %>
      <%= form.select :status, [["🏠 下書き（公開されません）", "draft"], ["🚀 公開する", "published"], ["🔒 非公開（管理用）", "hidden"]], {}, 
          class: "block w-full rounded-xl border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 transition-all" %>
    </div>
  </div>

  <%# アクションボタン %>
  <div class="flex items-center justify-end space-x-4">
    <%= link_to "キャンセル", admin_events_path, class: "text-sm font-bold text-gray-500 hover:text-gray-700 px-4 py-2" %>
    <%= form.submit "保存する", 
        class: "inline-flex items-center rounded-xl bg-indigo-600 px-8 py-4 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all active:scale-95 cursor-pointer" %>
  </div>
<% end %>
