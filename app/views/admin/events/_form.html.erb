<%= form_with(model: [:admin, event], class: "space-y-8") do |form| %>
  <%= render AdminUi::FormErrorsComponent.new(model: event) %>

  <%# セクション1: 基本情報 %>
  <%= render AdminUi::CardComponent.new(title: t('admin.views.events.form.section1_title')) do %>
    <p class="text-xs text-gray-500 font-medium mb-6"><%= t('admin.views.events.form.section1_subtitle') %></p>
    
    <div class="space-y-6">
      <div>
        <%= form.label :title %>
        <%= form.text_field :title, placeholder: t('admin.views.events.form.title_placeholder') %>
      </div>

      <div>
        <%= form.label :image %>
        <div class="mt-2 flex items-center gap-x-3">
          <% if event.image.attached? %>
            <%= image_tag event.image.variant(resize_to_limit: [200, 200]), class: "h-16 w-24 rounded-xl object-cover ring-1 ring-gray-900/10 shadow-sm" %>
          <% else %>
            <div class="h-16 w-24 rounded-xl bg-gray-50 flex items-center justify-center ring-1 ring-gray-900/10 border-2 border-dashed border-gray-200">
              <%= icon(:image, class: "h-6 w-6 text-gray-300") %>
            </div>
          <% end %>
          <div class="flex-grow">
            <%= form.file_field :image, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 transition-all cursor-pointer" %>
            <p class="mt-1 text-[10px] text-gray-400"><%= t('admin.views.events.form.image_hint') %></p>
          </div>
        </div>
      </div>

      <div>
        <%= form.label :event_type_id %>
        <%= form.collection_select :event_type_id, EventType.all, :id, :name, { prompt: t('admin.views.events.form.type_prompt') } %>
      </div>
    </div>
  <% end %>

  <%# セクション2: 開催日時・場所 %>
  <%= render AdminUi::CardComponent.new(title: t('admin.views.events.form.section2_title')) do %>
    <p class="text-xs text-gray-500 font-medium mb-6"><%= t('admin.views.events.form.section2_subtitle') %></p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
      <div class="md:col-span-2">
        <%= form.label :location %>
        <%= form.text_field :location, placeholder: t('admin.views.events.form.location_placeholder') %>
      </div>

      <div>
        <%= form.label :held_at %>
        <%= form.datetime_field :held_at %>
      </div>

      <div>
        <%= form.label :capacity %>
        <%= form.number_field :capacity, min: 1 %>
      </div>
    </div>
  <% end %>

  <%# セクション3: 公開設定 %>
  <%= render AdminUi::CardComponent.new(title: t('admin.views.events.form.section3_title')) do %>
    <p class="text-xs text-gray-500 font-medium mb-6"><%= t('admin.views.events.form.section3_subtitle') %></p>

    <%= form.label :status %>
    <%= form.select :status, [
        [t('admin.views.events.form.status_options.draft'), "draft"], 
        [t('admin.views.events.form.status_options.published'), "published"], 
        [t('admin.views.events.form.status_options.hidden'), "hidden"]
      ], {} %>
  <% end %>

  <%# アクションボタン %>
  <div class="flex items-center justify-end space-x-4">
    <%= link_to t('common.actions.cancel'), admin_events_path, class: "text-sm font-bold text-gray-500 hover:text-gray-700 px-4 py-2" %>
    <%= form.submit t('common.actions.save'), 
        class: "inline-flex items-center rounded-xl bg-indigo-600 px-8 py-4 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all active:scale-95 cursor-pointer" %>
  </div>
<% end %>
