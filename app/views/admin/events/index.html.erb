<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%# パンくずリスト %>
  <%= render AdminUi::Layout::BreadcrumbsComponent.new(breadcrumbs: [{ name: t('admin.views.events.index.breadcrumb') }]) %>

  <%# タイトルセクション %>
  <%= render AdminUi::Layout::PageHeaderComponent.new(
      title: t('admin.views.events.index.title'),
      subtitle: t('admin.views.events.index.subtitle')
  ) do |c| %>
    <% c.with_action do %>
      <%= link_to new_admin_event_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <%= icon(:plus, class: "h-5 w-5 mr-2") %>
        <%= t('admin.views.events.index.new') %>
      <% end %>
    <% end %>
  <% end %>
  
  <%# 検索フォーム %>
  <%= render AdminUi::Events::SearchFormComponent.new(params: params) %>

  <%# イベント一覧テーブル %>
  <%= render AdminUi::Events::TableComponent.new(events: @events, pagy: @pagy) %>
</div>
