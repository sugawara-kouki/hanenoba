<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render Layout::Admin::BreadcrumbsComponent.new(breadcrumbs: [{ name: "イベント一覧" }]) %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-bold text-gray-900 leading-tight"><%= t('admin.views.events.index.title') %></h1>
      <p class="mt-2 text-sm text-gray-500 font-medium"><%= t('admin.views.events.index.subtitle') %></p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_admin_event_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t('admin.views.events.index.new') %>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="overflow-x-auto shadow-sm ring-1 ring-gray-900/5 rounded-3xl border border-gray-100 bg-white">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50/50">
          <tr>
            <th scope="col" class="py-4 pl-8 pr-3 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
              <%= sort_link "title", t('admin.views.events.index.table.title') %>
            </th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest w-40">
              <%= sort_link "held_at", t('admin.views.events.index.table.held_at') %>
            </th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest w-52">
              <%= sort_link "capacity", t('admin.views.events.index.table.capacity') %>
            </th>
            <th scope="col" class="px-3 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest w-28">
              <%= sort_link "status", t('admin.views.events.index.table.status') %>
            </th>
            <th scope="col" class="relative py-4 pl-3 pr-8 text-right w-44">
              <span class="sr-only">操作</span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% if @events.any? %>
            <% @events.each do |event| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="py-5 pl-8 pr-3">
                  <div class="flex flex-col space-y-1">
                    <span class="inline-flex items-center w-fit px-2 py-0.5 rounded-md text-[10px] font-bold bg-indigo-50 text-indigo-600 ring-1 ring-indigo-500/10 uppercase tracking-tighter">
                      <%= event.event_type.name %>
                    </span>
                    <span class="text-base font-bold text-gray-900 leading-snug"><%= event.title %></span>
                    <div class="flex items-center text-xs text-gray-400 font-medium">
                      <svg class="h-3 w-3 mr-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <%= event.location %>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-5">
                  <div class="tabular-nums">
                    <div class="text-gray-900 font-semibold text-sm"><%= event.held_at.strftime("%Y/%m/%d") %></div>
                    <div class="text-xs text-gray-400 font-medium mt-0.5"><%= event.held_at.strftime("%H:%M") %>〜</div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-5">
                  <div class="flex flex-col space-y-1.5">
                    <div class="flex justify-between items-baseline tabular-nums">
                      <span class="text-sm font-semibold text-gray-700"><%= event.bookings.count %> / <%= event.capacity %></span>
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-tighter"><%= event.occupancy_rate %>%</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-1 overflow-hidden">
                      <div class="bg-indigo-600 h-1 rounded-full shadow-[0_0_4px_rgba(79,70,229,0.3)]" style="width: <%= [event.occupancy_rate, 100].min %>%"></div>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-5">
                  <div class="flex items-center space-x-1.5">
                    <div class="h-1.5 w-1.5 rounded-full <%= event.published? ? 'bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.4)]' : 'bg-gray-300' %>"></div>
                    <span class="text-xs font-semibold <%= event.published? ? 'text-green-700' : 'text-gray-500' %>">
                      <%= event.status_ja %>
                    </span>
                  </div>
                </td>
                <td class="whitespace-nowrap py-5 pl-3 pr-8 text-right font-medium">
                  <div class="flex items-center justify-end -space-x-px">
                    <%= link_to [:admin, event], class: "p-2 rounded-l-xl border border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: t('common.actions.show') do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    <% end %>

                    <%= link_to edit_admin_event_path(event), class: "p-2 border-y border-x-0 border-gray-200 bg-white text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all shadow-sm", title: "編集" do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>

                    <%= button_to [:admin, event], method: :delete, class: "p-2 rounded-r-xl border border-gray-200 bg-white text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all shadow-sm", data: { turbo_confirm: "イベントを削除してもよろしいですか？この操作は取り消せません。" }, title: "削除" do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-8 py-20 text-center text-sm text-gray-400 bg-gray-50/30">
                <div class="flex flex-col items-center justify-center">
                  <svg class="h-12 w-12 text-gray-200 mb-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                  </svg>
                  <p class="font-semibold">イベントが見つかりませんでした。</p>
                  <p class="text-sm mt-1">新しいイベントを作成して始めましょう。</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  </div>
</div>
