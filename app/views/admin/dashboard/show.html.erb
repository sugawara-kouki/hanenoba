<% content_for :title, "Dashboard | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render "admin/shared/breadcrumbs", breadcrumbs: [] %>

  <div class="mb-10 sm:flex sm:items-center sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-3xl font-black text-gray-900 leading-tight">ダッシュボード</h1>
      <p class="mt-2 text-sm text-gray-500">運営状況のサマリーと最近のアクティビティを確認できます。</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to new_admin_event_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        新規イベント作成
      <% end %>
    </div>
  </div>

  <%# 統計カードセクション %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
    <%# ユーザー数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group">
      <div class="absolute -right-4 -top-4 text-indigo-50/50 transform rotate-12 group-hover:scale-110 transition-transform duration-500">
        <svg class="h-32 w-32" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">Total Users</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_users %></p>
        <p class="text-xs text-indigo-600 font-bold">登録済みメンバー</p>
      </div>
    </div>

    <%# イベント数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group">
      <div class="absolute -right-4 -bottom-4 text-purple-50/50 transform -rotate-12 group-hover:scale-110 transition-transform duration-500">
        <svg class="h-32 w-32" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">Total Projects</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_events %></p>
        <p class="text-xs text-purple-600 font-bold">全イベント数</p>
      </div>
    </div>

    <%# 申込数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group sm:col-span-2 lg:col-span-1">
      <div class="absolute -right-4 -top-8 text-pink-50/50 transform group-hover:scale-110 transition-transform duration-500">
        <svg class="h-32 w-32" fill="currentColor" viewBox="0 0 24 24">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">Total Bookings</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_bookings %></p>
        <p class="text-xs text-pink-600 font-bold">累計申し込み数</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
    <%# 直近の申込 %>
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em]">Recent Bookings</h2>
        <%= link_to admin_events_path, class: "text-[10px] font-black text-indigo-600 hover:text-indigo-700 transition-colors uppercase" do %>
          view all
        <% end %>
      </div>
      <div class="bg-white rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
        <div class="divide-y divide-gray-50">
          <% if @recent_bookings.any? %>
            <% @recent_bookings.each do |booking| %>
              <div class="px-8 py-5 flex items-center justify-between hover:bg-gray-50/50 transition-colors">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <%= image_tag booking.user.image || "https://ui-avatars.com/api/?name=#{booking.user.name}", class: "h-9 w-9 rounded-xl ring-2 ring-gray-50 shadow-sm" %>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900 leading-tight"><%= booking.user.name %></p>
                    <p class="text-xs text-gray-400"><%= booking.event.title %></p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-black text-gray-400 mb-0.5"><%= time_ago_in_words(booking.created_at) %>前</p>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded-lg text-[10px] font-bold bg-green-50 text-green-600 ring-1 ring-green-600/10 uppercase">Applied</span>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-12 text-center">
              <p class="text-sm text-gray-400 font-bold">まだ申し込みはありません</p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# 今後のイベント %>
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em]">Upcoming Events</h2>
      </div>
      <div class="space-y-4">
        <% if @upcoming_events.any? %>
          <% @upcoming_events.each do |event| %>
            <%= link_to admin_event_path(event), class: "block bg-white p-6 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 hover:ring-indigo-600/20 transition-all group" do %>
              <div class="flex items-start justify-between">
                <div>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-tighter bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10 mb-2">
                    <%= event.event_type.name %>
                  </span>
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-indigo-600 transition-colors"><%= event.title %></h3>
                  <div class="mt-2 flex items-center text-xs text-gray-400 font-bold">
                    <svg class="h-3 w-3 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    </svg>
                    <%= event.location %>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-xl font-black text-gray-900 leading-none mb-1"><%= event.held_at.strftime("%m.%d") %></p>
                  <p class="text-[10px] font-black text-indigo-600 uppercase tracking-widest"><%= event.held_at.strftime("%H:%M") %></p>
                </div>
              </div>
              <%# 申込状況ミニバー %>
              <div class="mt-4">
                <div class="flex items-center justify-between text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1.5">
                  <span>Capacity</span>
                  <span><%= event.bookings.count %> / <%= event.capacity %></span>
                </div>
                <div class="w-full bg-gray-50 rounded-full h-1.5 overflow-hidden">
                  <div class="bg-indigo-600 h-full rounded-full transition-all duration-1000" style="width: <%= [event.bookings.count.to_f / event.capacity * 100, 100].min %>%"></div>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="bg-gray-50/50 rounded-[2rem] p-12 text-center ring-1 ring-gray-900/5 ring-inset">
            <p class="text-sm text-gray-400 font-bold italic">今後の予定はありません</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
