<% content_for :title, "Dashboard | Hanenoba Admin" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <%= render AdminUi::Layout::BreadcrumbsComponent.new(breadcrumbs: []) %>

  <% if @pending_users_count > 0 %>
    <div class="mb-8 bg-amber-50 border border-amber-200 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-pulse">
      <div class="flex items-center">
        <div class="bg-amber-100 p-2 rounded-lg text-amber-600 mr-4">
          <%= icon(:exclamation_triangle, class: "h-5 w-5") %>
        </div>
        <div>
          <p class="text-sm font-bold text-amber-900">承認待ちのユーザーが <span class="text-lg font-black"><%= @pending_users_count %></span> 名います。</p>
          <p class="text-xs text-amber-700 font-medium">コミュニティへの参加を許可するには承認作業が必要です。</p>
        </div>
      </div>
      <%= link_to admin_users_path, class: "bg-amber-600 hover:bg-amber-700 text-white text-xs font-bold py-2 px-4 rounded-xl shadow-lg shadow-amber-200 transition-all" do %>
        ユーザー管理へ
      <% end %>
    </div>
  <% end %>

  <%= render AdminUi::Layout::PageHeaderComponent.new(
        title: t('admin.views.dashboard.show.title'),
        subtitle: t('admin.views.dashboard.show.subtitle')
      ) do |c| %>
    <% c.with_action do %>
      <%= link_to new_admin_event_path, class: "inline-flex items-center rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-indigo-100 hover:bg-indigo-500 transition-all active:scale-95" do %>
        <%= icon(:plus, class: "h-5 w-5 mr-2") %>
        新規イベント作成
      <% end %>
    <% end %>
  <% end %>

  <%# 統計カードセクション %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
    <%# ユーザー数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group">
      <div class="absolute -right-4 -top-4 text-indigo-50/50 transform rotate-12 group-hover:scale-110 transition-transform duration-500">
        <%= icon(:users, class: "h-32 w-32") %>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">ユーザー総数</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_users %></p>
        <p class="text-xs text-indigo-600 font-bold">登録済みメンバー</p>
      </div>
    </div>

    <%# イベント数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group">
      <div class="absolute -right-4 -bottom-4 text-purple-50/50 transform -rotate-12 group-hover:scale-110 transition-transform duration-500">
        <%= icon(:calendar, class: "h-32 w-32") %>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">イベント総数</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_events %></p>
        <p class="text-xs text-purple-600 font-bold">全イベント数</p>
      </div>
    </div>

    <%# 申込数 %>
    <div class="bg-white p-8 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 relative overflow-hidden group sm:col-span-2 lg:col-span-1">
      <div class="absolute -right-4 -top-8 text-pink-50/50 transform group-hover:scale-110 transition-transform duration-500">
        <%= icon(:check_circle, class: "h-32 w-32") %>
      </div>
      <div class="relative z-10">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">累計申込数</p>
        <p class="text-4xl font-black text-gray-900 leading-none mb-1"><%= @total_bookings %></p>
        <p class="text-xs text-pink-600 font-bold">累計申し込み数</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
    <%# 直近の申込 %>
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em]">直近の申し込み</h2>
        <%= link_to admin_events_path, class: "text-[10px] font-black text-indigo-600 hover:text-indigo-700 transition-colors uppercase" do %>
          全て見る
        <% end %>
      </div>
      <div class="bg-white rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
        <div class="divide-y divide-gray-50">
          <% if @recent_bookings.any? %>
            <% @recent_bookings.each do |booking| %>
              <div class="px-8 py-5 flex items-center justify-between hover:bg-gray-50/50 transition-colors">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <%= image_tag booking.user.image || "https://ui-avatars.com/api/?name=#{booking.user.name}", class: "h-9 w-9 rounded-xl ring-2 ring-gray-50 shadow-sm" %>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900 leading-tight"><%= booking.user.name %></p>
                    <p class="text-xs text-gray-400"><%= booking.event.title %></p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-black text-gray-400 mb-0.5"><%= time_ago_in_words(booking.created_at) %>前</p>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded-lg text-[10px] font-bold bg-green-50 text-green-600 ring-1 ring-green-600/10 uppercase">申込完了</span>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-12 text-center">
              <p class="text-sm text-gray-400 font-bold">まだ申し込みはありません</p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# 今後のイベント %>
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em]">今後のイベント予定</h2>
      </div>
      <div class="space-y-4">
        <% if @upcoming_events.any? %>
          <% @upcoming_events.each do |event| %>
            <%= link_to admin_event_path(event), class: "block bg-white p-6 rounded-[2rem] shadow-sm ring-1 ring-gray-900/5 hover:ring-indigo-600/20 transition-all group" do %>
              <div class="flex items-start justify-between">
                <div>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-tighter bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10 mb-2">
                    <%= event.event_type.name %>
                  </span>
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-indigo-600 transition-colors"><%= event.title %></h3>
                  <div class="mt-2 flex items-center text-xs text-gray-400 font-bold">
                    <%= icon(:location, class: "h-3 w-3 mr-1.5") %>
                    <%= event.location %>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-xl font-black text-gray-900 leading-none mb-1"><%= l(event.held_at, format: :dot_date) %></p>
                  <p class="text-[10px] font-black text-indigo-600 uppercase tracking-widest"><%= l(event.held_at, format: :hm) %></p>
                </div>
              </div>
              <%# 申込状況ミニバー %>
              <div class="mt-4">
                <div class="flex items-center justify-between text-xs font-bold mb-2">
                  <span class="text-gray-900 group-hover:text-indigo-600 transition-colors truncate pr-4"><%= event.title %></span>
                  <span class="text-gray-400 whitespace-nowrap"><%= event.bookings.count %> / <%= event.capacity %></span>
                </div>
                <div class="w-full bg-gray-100/50 rounded-full h-1.5 overflow-hidden ring-1 ring-gray-900/5">
                  <div class="bg-indigo-600 h-full rounded-full transition-all duration-1000" style="width: <%= [event.occupancy_rate, 100].min %>%"></div>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="bg-gray-50/50 rounded-[2rem] p-12 text-center ring-1 ring-gray-900/5 ring-inset">
            <p class="text-sm text-gray-400 font-bold italic">今後の予定はありません</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
