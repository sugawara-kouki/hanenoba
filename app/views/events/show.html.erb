<div class="space-y-10">
  <%# パンくず風トップバー %>
  <div class="flex items-center justify-between">
    <%= link_to events_path, class: "group flex items-center text-sm font-black text-gray-400 hover:text-indigo-600 transition-all uppercase tracking-widest" do %>
      <div class="mr-2 p-1.5 rounded-lg bg-white shadow-sm ring-1 ring-black/5 group-hover:bg-indigo-50 transition-colors">
        <%= icon(:chevron_left, class: "h-4 w-4") %>
      </div>
      <%= t('events.show.back_to_discover') %>
    <% end %>
  </div>

  <div class="relative">
    <div class="bg-white rounded-[3rem] shadow-xl shadow-indigo-500/5 ring-1 ring-gray-900/5 overflow-hidden">
      <%# リッチなビジュアルヘッダー %>
      <div class="relative h-80 sm:h-96 w-full overflow-hidden">
        <% if @event.image.attached? %>
          <%= image_tag @event.image.variant(resize_to_limit: [1200, 800]), 
                       class: "absolute inset-0 w-full h-full object-cover", 
                       alt: @event.title %>
        <% else %>
          <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" 
               class="absolute inset-0 w-full h-full object-cover" 
               alt="<%= @event.title %>">
        <% end %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
        
        <%# カテゴリーフローティングバッジ %>
        <div class="absolute bottom-10 left-10 z-20">
          <span class="inline-flex items-center px-4 py-1.5 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] bg-white/20 backdrop-blur-md text-white border border-white/30 ring-1 ring-white/10 shadow-2xl">
            <%= @event.event_type.name %>
          </span>
          <h1 class="mt-4 text-3xl sm:text-5xl font-black text-white leading-tight drop-shadow-2xl">
            <%= @event.title %>
          </h1>
        </div>
      </div>

      <%# コンテンツ本文 %>
      <div class="p-6 sm:p-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-16">
          <div class="lg:col-span-2 space-y-12">
            <%# イベント概要セクション %>
            <section>
              <h2 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6"><%= t('events.show.event_details') %></h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div class="flex items-start">
                  <div class="bg-indigo-50 p-4 rounded-2xl text-indigo-600 shadow-sm ring-1 ring-indigo-600/10">
                    <%= icon(:calendar, class: "h-6 w-6") %>
                  </div>
                  <div class="ml-5">
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1"><%= t('events.show.date_time') %></p>
                    <p class="text-xl font-black text-gray-900 leading-tight">
                      <%= l(@event.held_at, format: :dot_date) %>
                    </p>
                    <p class="text-indigo-600 font-bold mt-1">
                      <%= l(@event.held_at, format: :hm) %> START
                    </p>
                  </div>
                </div>

                <div class="flex items-start">
                  <div class="bg-purple-50 p-4 rounded-2xl text-purple-600 shadow-sm ring-1 ring-purple-600/10">
                    <%= icon(:location, class: "h-6 w-6") %>
                  </div>
                  <div class="ml-5">
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1"><%= t('events.show.location') %></p>
                    <p class="text-xl font-black text-gray-900 leading-tight">
                      <%= @event.location %>
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <%# イベント説明（もしあれば） %>
            <section class="prose prose-indigo max-w-none prose-sm font-medium text-gray-600 leading-relaxed">
              <p><%= t('events.show.intro') %></p>
            </section>
          </div>

          <%# サイドバー：申し込み状況 %>
          <div class="space-y-8">
            <div class="bg-gray-50/50 rounded-[2rem] p-8 ring-1 ring-gray-900/5">
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-4 leading-none"><%= t('events.show.status') %></p>
              <div class="flex items-end justify-between mb-4">
                <span class="text-5xl font-black text-gray-900 leading-none"><%= @event.bookings.count %></span>
                <span class="text-gray-400 font-black text-xl leading-none">/ <%= @event.capacity %></span>
              </div>
              <%# プレミアム・進捗バー %>
              <div class="w-full bg-gray-200/50 rounded-full h-3 overflow-hidden">
                <div class="bg-gradient-to-r from-indigo-500 to-purple-600 h-full rounded-full shadow-lg shadow-indigo-500/20 transition-all duration-1000" 
                     style="width: <%= [@event.occupancy_rate, 100].min %>%"></div>
              </div>
              <p class="mt-6 text-[10px] text-gray-400 font-bold leading-relaxed">
                <%= t('events.show.capacity_hint', capacity: @event.capacity) %>
              </p>
            </div>

            <%# アクション %>
            <div id="booking_section">
              <%= render 'bookings/booking_section', event: @event, is_booked: @is_booked %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
