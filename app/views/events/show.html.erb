<%# app/views/events/show.html.erb %>
<div class="bg-gray-50 min-h-screen">
  <%# 戻るリンク %>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <%= link_to events_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewbox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      一覧に戻る
    <% end %>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
      <%# ヘッダービジュアル %>
      <div class="h-64 sm:h-80 w-full bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center relative">
        <div class="absolute inset-0 bg-black opacity-10"></div>
        <span class="text-white text-4xl sm:text-6xl font-black opacity-30 select-none uppercase tracking-widest">
          <%= @event.event_type.name %>
        </span>
      </div>

      <%# コンテンツ本文 %>
      <div class="p-8 sm:p-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold" style="background-color: <%= @event.event_type.color %>20; color: <%= @event.event_type.color %>;">
            <%= @event.event_type.name %>
          </span>
          <span class="text-gray-400 text-sm">作成日: <%= @event.created_at.strftime("%Y/%m/%d") %></span>
        </div>

        <h1 class="text-3xl sm:text-5xl font-black text-gray-900 mb-8 leading-tight">
          <%= @event.title %>
        </h1>

        <%# 詳細情報カード %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="flex-shrink-0 bg-indigo-50 p-3 rounded-xl text-indigo-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">開催日時</p>
                <p class="text-lg font-bold text-gray-900"><%= @event.held_at.strftime("%Y年 %m月 %d日") %></p>
                <p class="text-indigo-600 font-bold"><%= @event.held_at.strftime("%H:%M") %> 開始</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="flex-shrink-0 bg-pink-50 p-3 rounded-xl text-pink-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">開催場所</p>
                <p class="text-lg font-bold text-gray-900"><%= @event.location %></p>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="text-sm font-bold text-gray-900 mb-4">申し込み状況</h3>
            <div class="flex items-end justify-between mb-2">
              <span class="text-4xl font-black text-gray-900"><%= @event.bookings.count %></span>
              <span class="text-gray-400 font-bold text-lg">/ <%= @event.capacity %> 名</span>
            </div>
            <%# 進捗バー %>
            <div class="w-full bg-gray-200 rounded-full h-2.5">
              <div class="bg-indigo-600 h-2.5 rounded-full" style="width: <%= [@event.bookings.count.to_f / @event.capacity * 100, 100].min %>%"></div>
            </div>
            <p class="mt-4 text-xs text-gray-500 leading-relaxed">
              ※定員に達し次第、申し込みを締め切ります。キャンセルはLINE公式アカウントまでご連絡ください。
            </p>
          </div>
        </div>

        <%# 申し込みアクション %>
        <div class="border-t border-gray-100 pt-10">
          <% if @is_booked %>
            <div class="bg-green-50 border border-green-100 rounded-2xl p-6 text-center">
              <div class="inline-flex items-center justify-center p-3 bg-green-100 rounded-full text-green-600 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-green-900">申し込み済みです</h3>
              <p class="text-green-700 mt-1">当日のご来場をお待ちしております！</p>
            </div>
          <% elsif @event.bookings.count >= @event.capacity %>
            <div class="bg-red-50 border border-red-100 rounded-2xl p-6 text-center opacity-75">
              <h3 class="text-xl font-bold text-red-900">満員御礼</h3>
              <p class="text-red-700 mt-1">このイベントは定員に達したため、申し込みを締め切りました。</p>
            </div>
          <% else %>
            <%= button_to event_bookings_path(@event), 
                method: :post, 
                class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-5 px-8 rounded-2xl shadow-lg shadow-indigo-200 transform hover:-translate-y-1 transition-all text-xl flex items-center justify-center group",
                data: { turbo_confirm: "このイベントに申し込みますか？" } do %>
              参加を申し込む
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewbox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
