<%# app/views/events/_event_card.html.erb %>
<div class="group relative bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col h-full">
  <%# カードヘッダーイメージ（適当な色味を背景にする） %>
  <div class="aspect-w-16 aspect-h-9 w-full overflow-hidden bg-gradient-to-br from-indigo-500 to-purple-600 h-32 flex items-center justify-center">
    <span class="text-white text-4xl font-black opacity-20 uppercase"><%= event.event_type.name %></span>
  </div>

  <div class="p-6 flex flex-col flex-grow">
    <div class="flex items-center justify-between mb-3">
      <%# イベントタイプバッジ %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style="background-color: <%= event.event_type.color %>20; color: <%= event.event_type.color %>;">
        <%= event.event_type.name %>
      </span>
      <%# 定員情報 %>
      <span class="text-xs text-gray-400 font-medium">
        定員: <%= event.capacity %>名
      </span>
    </div>

    <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors">
      <%= event.title %>
    </h3>

    <%# 日時と場所のリスト %>
    <div class="mt-auto space-y-2">
      <div class="flex items-center text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <%= event.held_at.strftime("%Y年%m月%d日") %> 
        <span class="mx-1.5 text-gray-300">|</span>
        <%= event.held_at.strftime("%H:%M") %>開始
      </div>
      
      <div class="flex items-center text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-400" fill="none" viewbox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <%= event.location %>
      </div>
    </div>

    <%# ボタン %>
    <div class="mt-6 pt-4 border-t border-gray-50">
      <button class="w-full bg-gray-50 text-gray-700 font-bold py-3 px-4 rounded-xl hover:bg-indigo-600 hover:text-white transition-all duration-200">
        詳細を見る
      </button>
    </div>
  </div>
</div>
