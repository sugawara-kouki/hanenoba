<div class="bg-gray-50 min-h-screen pb-12">
  <%# ヒーローセクション %>
  <div class="bg-white border-b overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight sm:text-4xl">
            ハネノバ：イベント一覧
          </h1>
          <p class="mt-3 text-lg text-gray-500 max-w-2xl">
            現在募集中のイベントです。気になるイベントがあれば詳細をチェックしてみましょう。
          </p>
        </div>
        <div class="flex items-center space-x-3">
          <div class="flex -space-x-2 overflow-hidden">
             <%# ログイン中のユーザーアイコン（LINEから取得した画像があれば） %>
             <%= image_tag current_user.image || "https://ui-avatars.com/api/?name=#{current_user.name}&background=random", class: "inline-block h-10 w-10 rounded-full ring-2 ring-white", alt: current_user.name %>
          </div>
          <div class="text-sm font-medium text-gray-700">
            <%= current_user.name %> さん
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-10">
    <% if @events.any? %>
      <div class="grid grid-cols-1 gap-y-10 gap-x-6 sm:grid-cols-2 lg:grid-cols-3 xl:gap-x-8">
        <% @events.each do |event| %>
          <%= render "event_card", event: event %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center bg-white rounded-2xl shadow-sm border border-gray-100 py-20">
        <div class="flex justify-center mb-4 text-gray-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewbox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900">募集中のイベントはありません</h3>
        <p class="mt-1 text-sm text-gray-500">新しいイベントが追加されるのをお待ちください。</p>
      </div>
    <% end %>
  </div>

  <%# 簡易ログアウトボタン（フッター代わり） %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20 pt-8 border-t border-gray-200">
    <div class="flex justify-between items-center text-sm text-gray-500">
      <div>&copy; 2026 ハネノバ</div>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "hover:text-red-500 transition-colors underline decoration-gray-300 underline-offset-4" %>
    </div>
  </div>
</div>
