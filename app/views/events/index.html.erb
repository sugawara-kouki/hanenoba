<div class="space-y-12" data-controller="bulk-booking">
  <%# セクション見出し %>
  <div class="relative">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div class="relative z-10">
        <h1 class="text-4xl font-black text-gray-900 tracking-tight sm:text-5xl lg:text-6xl leading-[1.1]">
          <%= t('events.index.title') %>
        </h1>
        <p class="mt-4 text-base sm:text-lg text-gray-500 max-w-2xl font-medium leading-relaxed">
          <%= t('events.index.subtitle') %>
        </p>
      </div>
      
      <%# ステータス情報（右側） %>
      <div class="hidden lg:flex items-center space-x-4 bg-white/50 backdrop-blur-md p-4 rounded-3xl border border-white/20 shadow-xl shadow-indigo-500/5 ring-1 ring-black/5">
        <div class="flex -space-x-2 overflow-hidden">
          <%= image_tag current_user.image || "https://ui-avatars.com/api/?name=#{current_user.name}&background=random", class: "inline-block h-10 w-10 rounded-full ring-2 ring-white shadow-sm", alt: current_user.name %>
        </div>
        <div class="pr-2">
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none mb-1"><%= t('events.index.welcome_back') %></p>
          <p class="text-sm font-black text-gray-900 leading-none"><%= current_user.name %></p>
        </div>
      </div>
    </div>
  </div>

  <%# 検索フォーム %>
  <div class="mb-16 p-6 sm:p-12 bg-white/40 backdrop-blur-xl rounded-[3rem] border border-white/40 shadow-2xl shadow-indigo-500/5 ring-1 ring-black/5">
    <%= form_with url: events_path, method: :get, local: true, class: "space-y-12" do |f| %>
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-12 items-end">
        <%# キーワード %>
        <div class="flex-1 w-full space-y-3">
          <%= f.label :q, t('events.index.search.keyword'), class: "text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] ml-2" %>
          <%= f.text_field :q, value: params[:q], placeholder: t('common.search.placeholders.keyword'), 
              class: "block w-full rounded-2xl border-0 px-6 py-4 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-base font-bold transition-all h-16" %>
        </div>

        <%# 開催日 %>
        <div class="w-full lg:w-56 space-y-3">
          <%= f.label :date, t('events.index.search.date'), class: "text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] ml-2" %>
          <%= f.date_field :date, value: params[:date], 
              class: "block w-full px-8 rounded-3xl border-0 bg-white text-gray-900 shadow-sm ring-1 ring-inset ring-gray-200 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-base font-bold transition-all h-16" %>
        </div>

        <%# 残在庫数 %>
        <div class="w-full lg:w-48 space-y-3">
          <%= f.label :capacity, t('events.index.search.capacity'), class: "text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] ml-2" %>
          <div class="relative">
            <%= f.number_field :capacity, value: params[:capacity], min: 1, 
                class: "block w-full px-8 rounded-3xl border-0 bg-white text-gray-900 shadow-sm ring-1 ring-inset ring-gray-200 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-base font-bold transition-all text-center pr-12 h-16" %>
            <div class="absolute inset-y-0 right-6 flex items-center pointer-events-none">
              <span class="text-[10px] font-black text-gray-400 uppercase"><%= t('events.index.search.capacity_suffix') %></span>
            </div>
          </div>
        </div>

        <%# ボタン類 %>
        <div class="flex items-center space-x-4 w-full lg:w-auto h-16">
          <%= f.submit t('events.index.search.submit'), 
              class: "flex-1 bg-gray-900 hover:bg-gray-800 text-white font-black py-4 px-10 rounded-3xl transition-all active:scale-95 cursor-pointer shadow-xl shadow-gray-900/10 text-sm h-full" %>
          <%= link_to events_path, class: "bg-white hover:bg-gray-50 text-gray-500 font-black py-4 px-5 rounded-3xl transition-all active:scale-95 border border-gray-200 shadow-sm h-full flex items-center justify-center" do %>
            <%= icon(:refresh, class: "w-6 h-6") %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%= form_with url: bulk_create_event_bookings_path(event_id: @events.first&.id || 0), method: :post, local: true do |f| %>
    <div>
      <% if @events.any? %>
        <div class="grid grid-cols-1 gap-y-12 gap-x-8 sm:grid-cols-2 lg:grid-cols-3">
          <% @events.each do |event| %>
            <%= render Events::EventCardComponent.new(event: event, current_user: current_user) %>
          <% end %>
        </div>

        <% if @pagy.pages > 1 %>
          <div class="mt-8 flex justify-center">
            <%== @pagy.series_nav %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-24">
          <div class="flex justify-center mb-6">
            <div class="bg-gray-100 p-6 rounded-full">
              <%= icon(:calendar, class: "h-12 w-12 text-gray-300") %>
            </div>
          </div>
          <h3 class="text-xl font-black text-gray-900"><%= t('events.index.no_events') %></h3>
          <p class="mt-2 text-sm text-gray-500 font-medium"><%= t('events.index.no_events_subtitle') %></p>
        </div>
      <% end %>
    </div>

    <%# プレミアム・フローティング・バー %>
    <div data-bulk-booking-target="floatingBar" 
         class="fixed bottom-28 md:bottom-10 inset-x-4 sm:inset-x-auto sm:left-1/2 sm:-translate-x-1/2 z-50 transform translate-y-32 opacity-0 transition-all duration-500 cubic-bezier(0.34, 1.56, 0.64, 1)">
      <div class="bg-gray-900/90 backdrop-blur-xl text-white px-8 py-5 rounded-[2.5rem] shadow-2xl flex items-center space-x-8 border border-white/10 ring-1 ring-white/20">
        <div class="flex items-center space-x-4">
          <div class="bg-indigo-600 h-12 w-12 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/40">
            <%= icon(:plus, class: "h-6 w-6 text-white") %>
          </div>
          <div class="hidden sm:block">
            <p class="text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] mb-1"><%= t('events.index.selection_status') %></p>
            <p class="text-lg font-black tracking-tight"><span data-bulk-booking-target="countLabel">0</span> <span class="text-xs text-gray-400 font-bold ml-1"><%= t('events.index.items_selected') %></span></p>
          </div>
        </div>
        <%= f.submit t('events.index.bulk_apply'), 
            class: "bg-white hover:bg-gray-100 text-gray-900 font-black py-3.5 px-8 rounded-2xl transition-all active:scale-95 cursor-pointer shadow-xl",
            data: { confirm: t('events.index.confirm_bulk_apply') } %>
      </div>
    </div>
  <% end %>
</div>
