<%- if controller_name != 'sessions' %>
  <p><%= link_to t('devise.views.shared.links.login'), new_session_path(resource_name), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to t('devise.views.shared.links.sign_up'), new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p><%= link_to t('devise.views.shared.links.forgot_password'), new_password_path(resource_name), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to t('devise.views.shared.links.receive_confirmation'), new_confirmation_path(resource_name), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to t('devise.views.shared.links.receive_unlock'), new_unlock_path(resource_name), class: "text-blue-600 hover:text-blue-500 text-sm font-medium" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "#{OmniAuth::Utils.camelize(provider)}でログイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-blue-600 hover:text-blue-500 text-sm font-medium pointer-cursor" %></p>
  <% end %>
<% end %>
