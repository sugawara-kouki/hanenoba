<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hanenoba" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hanenoba">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet">

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 flex flex-col min-h-screen">
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center transition-all duration-300">
        <div class="flex items-center">
          <%= link_to root_path, class: "group flex items-center space-x-2" do %>
            <div class="bg-indigo-600 p-2 rounded-xl shadow-lg shadow-indigo-100 group-hover:bg-indigo-700 transition-colors">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <span class="text-2xl font-bold text-gray-900 tracking-tight"><%= t('views.layout.brand') %></span>
          <% end %>

          <% if user_signed_in? %>
            <div class="ml-10 hidden md:flex items-center space-x-8">
              <%= link_to events_path, class: "text-base font-bold transition-all uppercase tracking-widest #{controller_name == 'events' ? 'text-indigo-600' : 'text-gray-400 hover:text-gray-900'}" do %>
                <%= t('views.layout.discover') %>
              <% end %>
              <%= link_to mypage_calendar_path, class: "text-base font-bold transition-all uppercase tracking-widest #{controller_name == 'mypages' ? 'text-indigo-600' : 'text-gray-400 hover:text-gray-900'}" do %>
                <%= t('views.layout.my_schedule') %>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="flex items-center space-x-6">
          <% if user_signed_in? %>
            <div class="hidden sm:flex items-center space-x-3 pr-4 border-r border-gray-100">
              <div class="flex -space-x-1 overflow-hidden">
                <%= image_tag current_user.image || "https://ui-avatars.com/api/?name=#{current_user.name}&background=random", class: "inline-block h-8 w-8 rounded-full ring-2 ring-white shadow-sm", alt: current_user.name %>
              </div>
              <span class="text-base font-semibold text-gray-700"><%= current_user.name %></span>
            </div>
            <%= button_to t('views.layout.logout'), destroy_user_session_path, method: :delete, class: "text-base font-semibold text-gray-500 hover:text-red-500 transition-colors" %>
          <% elsif !admin_signed_in? %>
            <%= link_to t('views.layout.login'), new_user_session_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-xl shadow-lg shadow-indigo-100 transition-all active:scale-95" %>
          <% end %>

          <% if admin_signed_in? %>
            <%= link_to admin_root_path, class: "hidden sm:inline-flex items-center px-4 py-2 rounded-xl bg-gray-900 text-white text-sm font-semibold hover:bg-gray-800 transition-all" do %>
              <%= t('views.layout.admin_panel') %>
              <svg class="ml-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="flex-grow pb-24 md:pb-8">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <% if notice.present? %>
          <div class="mb-8 bg-indigo-50 border border-indigo-100 text-indigo-700 px-6 py-4 rounded-2xl flex items-center shadow-sm">
            <svg class="h-5 w-5 mr-3 text-indigo-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zm-1 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
            <span class="font-semibold"><%= notice %></span>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="mb-8 bg-red-50 border border-red-100 text-red-700 px-6 py-4 rounded-2xl flex items-center shadow-sm">
            <svg class="h-5 w-5 mr-3 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <span class="font-semibold uppercase tracking-tight"><%= alert %></span>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>

    <%# モバイル・ボトムナビゲーション %>
    <% if user_signed_in? %>
      <div class="md:hidden fixed bottom-6 inset-x-4 z-50">
        <nav class="bg-gray-900/90 backdrop-blur-xl border border-white/10 rounded-[2rem] shadow-2xl px-6 py-3 flex items-center justify-around ring-1 ring-white/20">
          <%= link_to events_path, class: "flex flex-col items-center space-y-1 group transition-all #{controller_name == 'events' ? 'text-white' : 'text-gray-500'}" do %>
            <div class="<%= controller_name == 'events' ? 'bg-indigo-600 shadow-lg shadow-indigo-500/40 p-2 rounded-xl text-white' : 'p-2' %> transition-all scale-100 group-active:scale-90">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-widest <%= controller_name == 'events' ? 'opacity-100' : 'opacity-40' %>"><%= t('views.layout.discover') %></span>
          <% end %>

          <%= link_to mypage_calendar_path, class: "flex flex-col items-center space-y-1 group transition-all #{controller_name == 'mypages' ? 'text-white' : 'text-gray-500'}" do %>
            <div class="<%= controller_name == 'mypages' ? 'bg-indigo-600 shadow-lg shadow-indigo-500/40 p-2 rounded-xl text-white' : 'p-2' %> transition-all scale-100 group-active:scale-90">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-widest <%= controller_name == 'mypages' ? 'opacity-100' : 'opacity-40' %>"><%= t('views.layout.my_schedule') %></span>
          <% end %>
        </nav>
      </div>
    <% end %>

    <footer class="bg-white border-t border-gray-100 py-12 pb-32 md:pb-12 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center text-gray-400">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="font-bold text-gray-900 tracking-tight"><%= t('views.layout.brand') %></span>
          <span class="text-base"><%= t('views.layout.footer_copy').html_safe %></span>
        </div>
        <div class="text-sm">
          <%= t('views.layout.footer_built') %>
        </div>
      </div>
    </footer>
  </body>
</html>
